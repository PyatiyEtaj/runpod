# Root paths on RunPod persistent storage.
WORKSPACE_DIR=/workspace
PROJECT_DIR=/workspace/ai-ver-2

# External apps. The bootstrap script clones these if they are missing.
COMFYUI_DIR=/workspace/ComfyUI
KOHYA_DIR=/workspace/kohya_ss
COMFYUI_VENV=/workspace/venv-comfyui
DATASET_VENV=/workspace/venv-dataset
KOHYA_VENV=/workspace/venv-kohya

# Dataset paths.
RAW_DATASET_DIR=/workspace/ai-ver-2/datasets/raw
PROCESSED_DATASET_DIR=/workspace/ai-ver-2/datasets/processed
TRAIN_DATASET_DIR=/workspace/ai-ver-2/datasets/flux_lora
DATASET_REPEATS=10
DATASET_CLASS_NAME=subject

# Model/output paths.
MODEL_DIR=/workspace/ai-ver-2/models
FLUX_MODEL_DIR=/workspace/ai-ver-2/models/flux
FLUX_DIFFUSION_MODEL_DIR=/workspace/ai-ver-2/models/flux/diffusion_models
FLUX_TEXT_ENCODER_DIR=/workspace/ai-ver-2/models/flux/text_encoders
FLUX_VAE_DIR=/workspace/ai-ver-2/models/flux/vae
JOYCAPTION_MODEL_DIR=/workspace/ai-ver-2/models/joycaption/llama-joycaption-alpha-two-hf-llava
RMBG_MODEL_DIR=/workspace/ai-ver-2/models/rmbg/RMBG-2.0
REALESRGAN_X4PLUS_MODEL=/workspace/ai-ver-2/models/upscaler/RealESRGAN_x4plus.pth
OUTPUT_DIR=/workspace/ai-ver-2/outputs/lora
SAMPLE_DIR=/workspace/ai-ver-2/outputs/samples
CACHE_DIR=/workspace/ai-ver-2/cache

# Hugging Face token is needed for gated FLUX.1-dev downloads.
HF_TOKEN=

# PyTorch wheel index. Use cu124 when RunPod host driver reports CUDA 12.4.
# For newer RunPod hosts you can switch this to https://download.pytorch.org/whl/cu128.
PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu124
TORCH_VERSION=2.6.0
TORCHVISION_VERSION=0.21.0
TORCHAUDIO_VERSION=2.6.0

# Dataset pipeline models.
JOYCAPTION_REPO=fancyfeast/llama-joycaption-alpha-two-hf-llava
RMBG_REPO=briaai/RMBG-2.0
REALESRGAN_X4PLUS_URL=https://github.com/xinntao/Real-ESRGAN/releases/download/v0.1.0/RealESRGAN_x4plus.pth

# FLUX.1-dev model files for Kohya and ComfyUI.
FLUX_DEV_REPO=black-forest-labs/FLUX.1-dev
FLUX_TEXT_ENCODERS_REPO=comfyanonymous/flux_text_encoders
FLUX_DEV_FILE=flux1-dev.safetensors
FLUX_AE_FILE=ae.safetensors
FLUX_CLIP_L_FILE=clip_l.safetensors
FLUX_T5XXL_FILE=t5xxl_fp16.safetensors

# Kohya defaults.
LORA_NAME=flux_subject_lora
KOHYA_CONFIG=/workspace/ai-ver-2/configs/kohya/flux_lora.toml
